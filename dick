-- // TINTWARE | DYNAMIC ENGINE UPGRADE // --

-- // SCRIPT KILLER (Prevents Interference) //
if getgenv().TintwareExecuted then
    getgenv().TintwareExecuted:Disconnect()
    if getgenv().TintwareInput then
        getgenv().TintwareInput:Disconnect()
    end
end

local Players = game:GetService("Players")
local RS = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Stats = game:GetService("Stats")
local StarterGui = game:GetService("StarterGui")
local Client = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local MainEvent = game:GetService("ReplicatedStorage"):WaitForChild("MAINEVENT")

-- // PREDICTION CACHE //
local LastVelocity = Vector3.new(0, 0, 0)

-- // NOTIFICATION HELPER //
local function notify(text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "TINTWARE V2", 
            Text = text, 
            Duration = 2
        })
    end)
end

local LockedPlayer = nil
local Tracer = Drawing.new("Line")
Tracer.Thickness = 1.5
Tracer.Visible = false

-- // DYNAMIC PING CALCULATION //
local function getPing()
    local pingValue = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    return (pingValue / 1000) -- Convert ms to seconds
end

-- // VISIBILITY CHECK //
local function isVisible(part)
    if not part or not part.Parent then return false end
    local char = Client.Character
    if not char then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, part.Parent}
    local ray = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
    return ray == nil
end

-- // THE BRAINS: DYNAMIC PREDICTION //
local function GetSmartPrediction(targetPart, config)
    local currentVelocity = targetPart.AssemblyLinearVelocity
    local ping = getPing()
    
    -- Calculate Acceleration (Delta Velocity)
    local acceleration = (currentVelocity - LastVelocity)
    LastVelocity = currentVelocity
    
    -- Prediction Time = (Ping + System Latency) * Sensitivity
    -- We add a small buffer for the remote event travel time
    local predictionTime = (ping + config.PredictionVelocity) 
    
    -- Physics Equation: Position + (Velocity * Time) + (0.5 * Acceleration * Time^2)
    local prediction = (currentVelocity * predictionTime) + (0.5 * acceleration * (predictionTime ^ 2))
    
    -- Gravity Compensation (If they are in the air, predict the fall)
    if currentVelocity.Y ~= 0 then
        prediction = prediction + Vector3.new(0, (workspace.Gravity * 0.5 * (predictionTime ^ 2)), 0)
    end
    
    return prediction
end

-- // MAIN HEARTBEAT //
getgenv().TintwareExecuted = RS.Heartbeat:Connect(function()
    local Config = getgenv().HyperConfig
    if not Config or not Config.Enabled or not LockedPlayer then 
        Tracer.Visible = false
        return 
    end

    local char = LockedPlayer.Character
    local targetPart = char and char:FindFirstChild(Config.HitPart)
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if not targetPart or not hum or (Config.KnockedCheck and hum.Health <= 0) then
        Tracer.Visible = false
        return
    end

    -- Get Smart Prediction
    local dynamicPred = GetSmartPrediction(targetPart, Config)
    
    -- Clamp for safety
    if dynamicPred.Magnitude > Config.MaxPredictionClamp then
        dynamicPred = dynamicPred.Unit * Config.MaxPredictionClamp
    end

    local finalPos = targetPart.Position + dynamicPred + Vector3.new(0, Config.VerticalOffset, 0)
    local tPos, tVis = Camera:WorldToViewportPoint(finalPos)
    
    -- Update Tracer
    Tracer.Color = Config.TracerColor
    if tVis then
        Tracer.Visible = true
        Tracer.From = UIS:GetMouseLocation()
        Tracer.To = Vector2.new(tPos.X, tPos.Y)
    else
        Tracer.Visible = false
    end

    -- Auto-Fire / Remote Call
    if isVisible(targetPart) then
        MainEvent:FireServer("MOUSE", finalPos)
    end
end)

-- // INPUT BIND //
getgenv().TintwareInput = UIS.InputBegan:Connect(function(i, gpe)
    local Config = getgenv().HyperConfig
    if gpe or not Config then return end
    
    if i.KeyCode == Enum.KeyCode.Q then
        if Config.Enabled then
            Config.Enabled = false
            LockedPlayer = nil
            Tracer.Visible = false
            notify("Unlocked")
        else
            local mousePos = UIS:GetMouseLocation()
            local closestPlayer = nil
            local dist = math.huge
            
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= Client and v.Character and v.Character:FindFirstChild(Config.HitPart) then
                    local tp = v.Character[Config.HitPart]
                    if isVisible(tp) then
                        local p, os = Camera:WorldToViewportPoint(tp.Position)
                        if os then
                            local d = (Vector2.new(p.X, p.Y) - mousePos).Magnitude
                            if d < dist then 
                                closestPlayer = v 
                                dist = d 
                            end
                        end
                    end
                end
            end
            
            if closestPlayer then
                LockedPlayer = closestPlayer
                Config.Enabled = true
                notify("Locked: " .. closestPlayer.DisplayName)
            end
        end
    end
end)
