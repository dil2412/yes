end)

local LockedPlayer = nil
local LastPosition = Vector3.new(0,0,0)
local LastVelocity = Vector3.new(0,0,0)
local Tracer = Drawing.new("Line")
Tracer.Thickness = 1.8
Tracer.Visible = false

local function getPing()
    return tonumber(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) or 0
end

local function notify(text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "TINTWARE | TESTING |", 
            Text = text, 
            Duration = 2
        })
    end)
end

local function isVisible(part)
    if not part or not part.Parent then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {Client.Character, part.Parent}
    local ray = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
    return ray == nil
end

-- // CORE ENGINE //
getgenv().TintwareExecuted = RS.Heartbeat:Connect(function(deltaTime)
    local Config = getgenv().HyperConfig
    if not Config or not Config.Enabled or not LockedPlayer then 
        Tracer.Visible = false
        LastPosition = Vector3.new(0,0,0)
        return 
    end

    local char = LockedPlayer.Character
    local targetPart = char and char:FindFirstChild(Config.HitPart)
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if not targetPart or not hum or (Config.KnockedCheck and hum.Health <= 0) then
        Tracer.Visible = false
        return
    end

    -- // ADVANCED VELOCITY & ACCEL //
    local currentPos = targetPart.Position
    local currentVel = (currentPos - LastPosition) / deltaTime
    
    -- Smooth out the velocity to prevent "jittery" tracers
    local smoothedVel = LastVelocity:Lerp(currentVel, 0.75) 
    
    LastPosition = currentPos
    LastVelocity = smoothedVel

    local ping = getPing()
    local pBoost = ping * Config.PingScaling
    
    -- Dynamic Scaling (Higher threshold for V16)
    local speed = smoothedVel.Magnitude
    local dynamicModifier = (speed < 40) and 0.92 or 1.0
    
    -- // PREDICTION MATH //
    -- We multiply Sens * Velocity * (Pred + Ping)
    local finalX = (smoothedVel.X * Config.VelocitySensX) * (Config.PredX + pBoost) * dynamicModifier
    local finalY = (smoothedVel.Y * Config.VelocitySensY) * (Config.PredY + pBoost) * dynamicModifier
    local finalZ = (smoothedVel.Z * Config.VelocitySensZ) * (Config.PredZ + pBoost) * dynamicModifier
    
    local finalPred = Vector3.new(finalX, finalY, finalZ)
    
    -- THE CLAMP
    if finalPred.Magnitude > Config.MaxPredictionClamp then
        finalPred = finalPred.Unit * Config.MaxPredictionClamp
    end

    local finalPos = currentPos + finalPred + Vector3.new(0, Config.VerticalOffset, 0)
    local tPos, tVis = Camera:WorldToViewportPoint(finalPos)
    
    Tracer.Color = Config.TracerColor
    if tVis then
        Tracer.Visible = true
        Tracer.From = UIS:GetMouseLocation()
        Tracer.To = Vector2.new(tPos.X, tPos.Y)
    else
        Tracer.Visible = false
    end

    -- TRIGGERBOT
    if isVisible(targetPart) and Config.TriggerBot then
        local tool = Client.Character:FindFirstChildOfClass("Tool")
        if tool and not tool:FindFirstChild("Safe") then
            MainEvent:FireServer("MOUSE", finalPos)
            tool:Activate()
        end
    end
end)

-- // INPUT BIND //
getgenv().TintwareInput = UIS.InputBegan:Connect(function(i, gpe)
    local Config = getgenv().HyperConfig
    if gpe or not Config then return end
    if i.KeyCode == Enum.KeyCode.Q then
        if Config.Enabled then
            Config.Enabled = false
            LockedPlayer = nil
            LastPosition = Vector3.new(0,0,0)
            Tracer.Visible = false
            notify("Unlocked")
        else
            local mousePos = UIS:GetMouseLocation()
            local closestPlayer = nil
            local dist = math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= Client and v.Character and v.Character:FindFirstChild(Config.HitPart) then
                    local tp = v.Character[Config.HitPart]
                    if isVisible(tp) then
                        local p, os = Camera:WorldToViewportPoint(tp.Position)
                        if os then
                            local d = (Vector2.new(p.X, p.Y) - mousePos).Magnitude
                            if d < dist then closestPlayer = v; dist = d end
                        end
                    end
                end
            end
            if closestPlayer then
                LockedPlayer = closestPlayer
                Config.Enabled = true
                notify("Locked onto " .. closestPlayer.DisplayName)
            else
                notify("no nigga visible")
            end
        end
    end
end)
